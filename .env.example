# Copier ce fichier en .env.dev ou .env.prod et remplir les valeurs réelles
# NE PAS commiter .env.dev ou .env.prod

APP_ENV=dev

TELEGRAM_BOT_TOKEN=VOTRE_TOKEN_ICI
GROQ_API_KEY=VOTRE_CLE_GROQ_ICI
DATABASE_URL=postgresql://potager_user:VOTRE_MOT_DE_PASSE@localhost/potager

# Authentification web JWT [US-044] — secret fort, jamais versionné
JWT_SECRET=VOTRE_SECRET_JWT_ICI
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
