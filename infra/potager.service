[Unit]
Description=Assistant Potager — Bot Telegram + API FastAPI
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=potager
WorkingDirectory=/opt/potager-prod
EnvironmentFile=/opt/potager-prod/.env.prod
Environment=APP_ENV=prod
ExecStart=/opt/potager-prod/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
