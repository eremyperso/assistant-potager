[Unit]
Description=Assistant Potager — DEV (Bot Telegram + API FastAPI)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/potager-dev
EnvironmentFile=/opt/potager-dev/.env.dev
Environment=APP_ENV=dev
ExecStart=/opt/potager-dev/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8001
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
